# ============================================================================
# SmartQuery Pro — Environment Variables
# ============================================================================
# Copy this file to .env.local for local development.
# On Vercel, add each of these under Project Settings → Environment Variables.
# ============================================================================


# ----------------------------------------------------------------------------
# REQUIRED — Authentication
# ----------------------------------------------------------------------------

# A random secret used to sign session tokens. Generate one with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=

# The canonical URL of your deployment.
# Local development:
#   NEXTAUTH_URL=http://localhost:3000
# Production (Vercel):
#   NEXTAUTH_URL=https://your-app.vercel.app
NEXTAUTH_URL=


# ----------------------------------------------------------------------------
# REQUIRED for persistence — MongoDB
# ----------------------------------------------------------------------------
# Without this, the demo account (demo@smartquery.com / password) can still
# sign in, but uploads, search, analytics, and AI features will return a
# friendly "not configured" message instead of working.
#
# Free tier: create a cluster at https://www.mongodb.com/cloud/atlas
# Connection string format:
#   mongodb+srv://<user>:<password>@<cluster-host>/<database-name>?retryWrites=true&w=majority
MONGODB_URI=


# ----------------------------------------------------------------------------
# OPTIONAL — AI features (Google Gemini)
# ----------------------------------------------------------------------------
# Powers AI query expansion, document summarization, and Q&A.
# Without this key, SmartQuery Pro runs in full "extractive" fallback mode:
#   - Core search (inverted index + BM25 + spell correction + synonym
#     expansion) works exactly the same.
#   - Summaries use an extractive (most information-dense sentences) algorithm.
#   - Q&A returns the best-matching document excerpt instead of a synthesized
#     answer.
#
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional override for the Gemini model used. Defaults to gemini-1.5-flash
# (fast and free-tier friendly). Other options: gemini-1.5-pro.
GEMINI_MODEL=gemini-1.5-flash


# ----------------------------------------------------------------------------
# OPTIONAL — Rate limiting
# ----------------------------------------------------------------------------
# Maximum optimizer-only requests (/api/search/optimize) per user per minute.
# Full /api/search requests are allowed at 3x this value; AI endpoints
# (/api/ai/summarize, /api/ai/qa) are fixed at 15/min.
RATE_LIMIT_OPTIMIZER_MAX=30
