# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── OpenAI (required for optimizer) ──────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

# ── MongoDB (required for history) ───────────────────────
# Free: mongodb.com/atlas → Free M0 cluster
# Format: mongodb+srv://<user>:<pass>@cluster.mongodb.net/smartquery
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/smartquery?retryWrites=true&w=majority

# ── Resend (required for contact emails) ─────────────────
# Free: resend.com → Create API key
RESEND_API_KEY=re_...
ADMIN_EMAIL=your@email.com
FROM_EMAIL=onboarding@resend.dev

# ── Auth ─────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-64-char-random-hex-here

# ── Rate Limits ───────────────────────────────────────────
RATE_LIMIT_OPTIMIZER_MAX=10
