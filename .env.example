# ══════════════════════════════════════════════════════════
#  QueryForge — Environment Variables
#  Copy this file to .env.local and fill in all values
# ══════════════════════════════════════════════════════════

# ── DATABASE (Neon PostgreSQL) ──────────────────────────
# Get both strings from neon.tech → your project → Connection String
DATABASE_URL="postgresql://user:pass@ep-xyz-123.us-east-2.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xyz-123.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── AUTH ────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
# Local dev → http://localhost:3000 | Production → your Vercel URL
NEXTAUTH_URL="http://localhost:3000"

# ── AI ENGINE ───────────────────────────────────────────
# You need at least ONE of these two. Setting both gives
# automatic failover (Claude primary, Gemini fallback).
#
# Anthropic Claude (primary engine):
#   Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY="sk-ant-api03-..."
#
# Google Gemini (fallback / free tier available):
#   Get from: aistudio.google.com/apikey  ← FREE, no billing required
#   If ANTHROPIC_API_KEY is invalid/missing, Gemini takes over automatically.
GEMINI_API_KEY="AIza..."

# ── OPTIONAL ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
