# ============================================================
# SMART QUERY OPTIMIZER — Environment Variables
# Copy this to .env.local and fill in your values
# ============================================================

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── REQUIRED: JWT Auth ───────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-this

# ── REQUIRED: Resend Email ───────────────────────────────────
# 1. Sign up free at https://resend.com
# 2. Go to API Keys → Create API Key
# 3. Paste the key below (starts with re_)
RESEND_API_KEY=re_YOUR_RESEND_API_KEY_HERE

# 4. YOUR Gmail address — contact form notifications go here
ADMIN_EMAIL=YOUR_GMAIL@gmail.com

# From address for sent emails
# Use onboarding@resend.dev while testing (works without domain verification)
# Once you verify a domain on Resend, change to: noreply@yourdomain.com
DEFAULT_FROM_EMAIL=onboarding@resend.dev

# ── OPTIONAL: Database (PostgreSQL) ─────────────────────────
# The app works without this (uses in-memory store in dev).
# Required for production persistence.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/smart_query_optimizer?schema=public"

# ── OPTIONAL: Node Environment ──────────────────────────────
NODE_ENV=development
