# ════════════════════════════════════════════════════════
#  SmartQuery SQL Optimizer — Environment Variables
#  Copy this file to .env.local for local development
#  Add ALL variables to Vercel → Settings → Environment Variables
# ════════════════════════════════════════════════════════

# ── AI Query Engine (REQUIRED — add at least one) ───────
# Primary engine: get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional fallback engine (app works fine without this)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Database (REQUIRED) ──────────────────────────────────
# Neon PostgreSQL → https://neon.tech (free tier available)
# In Neon dashboard: Connection Details → copy "Connection string"
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# In Neon dashboard: Connection Details → "Direct connection" toggle
DIRECT_URL=postgresql://user:password@host/dbname?sslmode=require

# ── NextAuth Authentication (REQUIRED) ───────────────────
# Generate secret: run this in terminal → openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here-min-32-chars

# Your deployed URL (no trailing slash)
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000

# ── Optional: Google OAuth (adds "Sign in with Google") ──
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
