# ============================================================
# Smart Query Optimizer — Environment Variables
# Copy this to .env.local and fill in your values
# ============================================================

# ─── App ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Smart Query Optimizer
NODE_ENV=development

# ─── OpenAI (AI Optimization Engine) ─────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# ─── MongoDB (Query History Storage) ─────────────────────
# Free: MongoDB Atlas → https://mongodb.com/atlas/database
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/smartquery?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster.mongodb.net/smartquery?retryWrites=true&w=majority

# ─── Resend (Contact Form Emails) ────────────────────────
# Free: https://resend.com → API Keys → Create Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_EMAIL=your@email.com
FROM_EMAIL=onboarding@resend.dev
FROM_NAME=Smart Query Optimizer

# ─── Auth ────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generate-a-64-char-random-hex-string-here

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_OPTIMIZER_MAX=10
RATE_LIMIT_CONTACT_MAX=3

# ─── Feature Flags ───────────────────────────────────────
NEXT_PUBLIC_ENABLE_HISTORY=true
NEXT_PUBLIC_ENABLE_EXAMPLES=true
NEXT_PUBLIC_MAX_QUERY_LENGTH=5000
