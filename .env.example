# ──────────────────────────────────────────────────────────────────────────
# SmartQuery — Environment Variables
# Copy this file to .env (local dev) or set these in your Vercel project
# Settings → Environment Variables (production).
#
# Only FIVE variables are required. No other AI provider keys are needed —
# SmartQuery runs entirely on Google Gemini.
# ──────────────────────────────────────────────────────────────────────────

# 1. Gemini API key — get one free at https://aistudio.google.com/app/apikey
#    SmartQuery automatically falls back across 5 Gemini models if one is
#    rate-limited or temporarily unavailable, so a single free-tier key is
#    enough to get started.
GEMINI_API_KEY=

# 2. PostgreSQL connection string (pooled) — e.g. from Neon, Supabase, or
#    any standard Postgres host. Used for normal request-time queries.
DATABASE_URL=

# 3. PostgreSQL connection string (direct, non-pooled) — required by Prisma
#    for migrations. On Neon this is usually the same host without
#    "-pooler" in the name.
DIRECT_URL=

# 4. NextAuth secret — any random 32+ character string.
#    Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=

# 5. The full URL your app is deployed at (no trailing slash).
#    Local dev:  http://localhost:3000
#    Production: https://your-app.vercel.app
NEXTAUTH_URL=
