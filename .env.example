# ─── DATABASE (Neon PostgreSQL) ──────────────────────────────
# From https://console.neon.tech → your project → Connection Details
# Use "Pooled connection" for DATABASE_URL (serverless)
# Use "Direct connection" for DIRECT_URL (migrations)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ─── NEXTAUTH ────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-32-char-minimum-key"
# Your deployed URL — update after first Vercel deploy
NEXTAUTH_URL="http://localhost:3000"

# ─── AI ENGINE ─────────────────────────────────────────────────
# At least ONE of these two is required. Claude is tried first; if it's
# missing, rate-limited, or temporarily down, the app automatically falls
# back to Gemini (if set) so the optimizer keeps working.

# From https://console.anthropic.com → API Keys (primary engine)
ANTHROPIC_API_KEY="sk-ant-api03-..."

# From https://aistudio.google.com/apikey (free tier available — automatic fallback engine)
GEMINI_API_KEY="AIza..."

# ─── APP SETTINGS ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Smart Query Optimizer"

# ─── RATE LIMITING ────────────────────────────────────────────
# Free tier: 20 optimizations/hour per user
RATE_LIMIT_MAX="20"
RATE_LIMIT_WINDOW_MS="3600000"
