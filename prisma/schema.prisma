// prisma/schema.prisma
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  queries     Query[]
  conversions Conversion[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Query {
  id               String   @id @default(cuid())
  userId           String
  originalQuery    String   @db.Text
  optimizedQuery   String   @db.Text
  domain           String?
  title            String?
  performanceGain  Int      @default(0)
  issues           Json     @default("[]")
  improvements     Json     @default("[]")
  indexRecs        Json     @default("[]")
  tablesDetected   Json     @default("[]")
  tags             Json     @default("[]")
  complexityBefore String?
  complexityAfter  String?
  estimatedSpeedup String?
  estimatedRowsScanned String?
  costScore        Int?
  readabilityNotes String?  @db.Text
  engine           String?  @default("ai")
  queryType        String   @default("SELECT")
  explanation      String?  @db.Text
  isFavorited      Boolean  @default(false)
  isShared         Boolean  @default(false)
  shareToken       String?  @unique @default(cuid())
  executionTimeMs  Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, domain])
  @@index([shareToken])
  @@map("queries")
}

// Tracks all feature usage: NL2SQL conversions, schema uploads, playground runs, etc.
model Conversion {
  id          String   @id @default(cuid())
  userId      String
  feature     String   // "nl2sql" | "schema_upload" | "playground_run" | "export"
  inputText   String?  @db.Text
  outputText  String?  @db.Text
  dialect     String?
  domain      String?
  success     Boolean  @default(true)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, feature])
  @@index([userId, createdAt(sort: Desc)])
  @@map("conversions")
}

enum Role {
  USER
  ADMIN
}
