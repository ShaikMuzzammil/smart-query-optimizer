# ============================================================
# SMART QUERY OPTIMIZER — .gitignore
# ============================================================

# ── NEVER COMMIT THESE ──────────────────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
*.pem
*.key
*.cert

# ── Dependencies ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
yarn.lock

# ── Next.js Build Output ─────────────────────────────────────
.next/
out/
dist/
build/

# ── Prisma ───────────────────────────────────────────────────
prisma/migrations/dev/

# ── Debug & Logs ─────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
logs/

# ── OS Files ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editor ───────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.user
.project
.classpath

# ── Misc ─────────────────────────────────────────────────────
.vercel
.turbo
coverage/
.nyc_output
